# ═══════════════════════════════════════════════════════════════════
#  O.R.I.O.N. — Environment Configuration Template
#  Copy this file to .env and fill in your values.
#  Never commit the .env file — it is gitignored.
# ═══════════════════════════════════════════════════════════════════

# ─── App ────────────────────────────────────────────────────────────
APP_ENV=development                  # development | production
APP_PORT=8000
FRONTEND_URL=http://localhost:3000

# ─── LLM Provider — Tier 1 (Primary) ───────────────────────────────
# Set PROVIDER to: ollama | openai | anthropic | google | openrouter
LLM_TIER1_PROVIDER=ollama
LLM_TIER1_MODEL=llama3
LLM_TIER1_BASE_URL=http://localhost:11434   # Ollama local server URL

# ─── LLM Provider — Tier 2 (First Fallback) ────────────────────────
LLM_TIER2_PROVIDER=openrouter
LLM_TIER2_MODEL=mistralai/mistral-7b-instruct
LLM_TIER2_API_KEY=your_openrouter_api_key_here

# ─── LLM Provider — Tier 3 (Final Fallback) ────────────────────────
LLM_TIER3_PROVIDER=anthropic
LLM_TIER3_MODEL=claude-haiku-4-5-20251001
LLM_TIER3_API_KEY=your_anthropic_api_key_here

# ─── Additional Provider Keys (optional, for UI config panel) ───────
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# ─── Voice — TTS ────────────────────────────────────────────────────
TTS_ENGINE=browser                   # browser (free) | coqui | elevenlabs | openai
ELEVENLABS_API_KEY=your_elevenlabs_key_here
ELEVENLABS_VOICE_ID=your_voice_id_here

# ─── Voice — STT ────────────────────────────────────────────────────
STT_ENGINE=browser                   # browser (free) | whisper_local | whisper_api
OPENAI_WHISPER_API_KEY=your_openai_key_here

# ─── Memory / Database ──────────────────────────────────────────────
DATABASE_URL=sqlite:///./orion_memory.db

# ─── Session ────────────────────────────────────────────────────────
SECRET_KEY=change_this_to_a_random_secret_key_32chars
SESSION_MAX_HISTORY=50               # max messages to retain per session
